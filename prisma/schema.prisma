generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model InvestmentProject {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String?
  round       String?
  manager     String?
  tags        String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
