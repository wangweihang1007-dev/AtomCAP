generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 用户与认证 ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?   @map("password_hash")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  sessions Session[]
  projects Project[]  @relation("CreatedProjects")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ==================== 项目管理 ====================

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String?  @default("设立期")
  priority    String?  @default("中")
  industry    String?
  stage       String?
  budget      Float?
  
  //US002扩展的字段
  logo            String?  @db.VarChar(20)
  tags            String?  @db.VarChar(50)
  round           String?  @db.VarChar(50)
  managerId       String?  @db.VarChar(100)
  managerName     String?  @db.VarChar(100)
  totalInvestment Float?
  irr             Float?

  creatorId   String   @map("creator_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator   User       @relation("CreatedProjects", fields: [creatorId], references: [id], onDelete: Cascade)
  tasks     Task[]
  documents Document[]

  @@map("projects")
}

model Task {
  id          String    @id @default(cuid())
  projectId   String    @map("project_id")
  title       String
  description String?
  status      String    @default("pending")
  priority    String?   @default("中")
  assignee    String?
  dueDate     DateTime? @map("due_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model Document {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  name      String
  format    String?
  size      String?
  category  String?
  url       String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("documents")
}
//数据看板前四块
model DashboardOverview {
  id                     String   @id @default(cuid())
  totalProjectCount      Int      @default(0)
  totalInvestment        Float?
  fundCount              Int      @default(0)
  newProjectCount        Int      @default(0)
  irrMedian              Float?
  dpiDistribution        String?  @db.VarChar(50)
  avgReturnMultiple      Float?
  exitWinRate            Float?
  avgProjectDuration     Int?
  invalidEfficiency      Float?
  approvalPassRate       Float?
  highRiskProjectCount   Int      @default(0)
  compliancePendingCount Int      @default(0)
  todayMeetingCount      Int      @default(0)
  updatedAt              DateTime @updatedAt
}
//数据看板中间四块
model DashboardChart {
  id                     String  @id @default(cuid())
  trackName              String? @db.VarChar(50)
  trackInvestAmount      Float?
  trackRatio             Float?
  stageName              String? @db.VarChar(50)
  stageProjectCount      Int?
  statisticMonth         String? @db.VarChar(20)
  quarter                String? @db.VarChar(20)
  fundIrr                Float?
  industryTopIrr         Float?
  industryAvgIrr         Float?
  managerName            String? @db.VarChar(50)
  managerProjectCount    Int?
  managerAvgCycle        Int?
  managerEfficiencyScore Int?
}
//数据看板待办
model DashboardTodo {
  id          String    @id @default(cuid())
  type        String?   @db.VarChar(50)
  title       String?   @db.VarChar(255)
  projectName String?   @db.VarChar(255)
  submitter   String?   @db.VarChar(50)
  submitTime  DateTime?
  deadline    DateTime?
  priority    String?   @db.VarChar(20)
  operation   String?   @db.VarChar(20)
  createdAt   DateTime  @default(now())
}
//策略中心
model Strategy {
  id              String   @id @default(cuid())
  iconName        String?  @db.VarChar(50)
  name            String   @db.VarChar(255)
  frameworkName   String?  @db.VarChar(255)
  description     String?
  managerName     String?  @db.VarChar(100)
  projectCount    Int      @default(0)
  totalInvestment String?  @db.VarChar(50)
  returnRate      String?  @db.VarChar(50)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
